# Copy to .env and fill in. Never commit the real .env.

# RPC endpoint. For BSC mainnet, use your own node or a paid provider
# endpoint you trust (Ankr, QuickNode, NodeReal, etc.) - do not rely on
# random public endpoints for anything that signs and broadcasts txs.
RPC_URL=

# Hot wallet private key for the KEEPER role (NOT the owner/multisig key).
# This key can only call executeArbitrage() on the contract below - it can't
# change whitelists, caps, or withdraw funds. Fund it with just enough BNB
# for gas. Keep it out of git; load it from a secrets manager in production.
#
# OPTIONAL when DRY_RUN=true: a pure simulate-and-log run never signs or
# broadcasts anything, so it doesn't need a real wallet. Required (and
# validated at startup) the moment DRY_RUN=false.
PRIVATE_KEY=

# Deployed AaveArbitrageExecutorV3 address.
#
# OPTIONAL when DRY_RUN=true AND SCAN_MODE=dynamic: without it, the scanner
# still generates and prices real candidate routes straight from DEX
# contracts over RPC, using a local replica of the fixed 0.05% Aave flash-loan
# premium in place of the contract's estimateFlashLoanFee(), and reports gas
# cost as "unknown" (no deployed contract's Chainlink feeds to query) instead
# of calling estimateGasCostInAsset(). Still required for SCAN_MODE=static
# even in dry-run - that mode's whole profitability check IS the deployed
# contract's own on-chain quoting logic, there's no local fallback for it.
# Always required the moment DRY_RUN=false.
EXECUTOR_ADDRESS=

# "dynamic" (default): multi-DEX/multi-asset/multi-hop auto-scanner, driven
#   by routes.config.json - generates and prices candidate routes every poll.
# "static": fixed hand-authored routes from strategies.json - use this if you
#   want the bot restricted to one specific, manually-audited route.
SCAN_MODE=dynamic

# Path to the dynamic-mode route config (see routes.config.example.json).
ROUTES_CONFIG_FILE=./routes.config.json

# Path to the static-mode strategies file (see strategies.example.json).
STRATEGIES_FILE=./strategies.json

# "poll" (default): fixed-interval re-scan every POLL_INTERVAL_MS - safest
#   against a rate-limited public RPC since you control the exact cadence.
# "block": re-scan on every new block for continuous evaluation - works with
#   both a WebSocket RPC_URL (wss://..., true push) and a plain HTTP RPC_URL
#   (ethers transparently polls eth_blockNumber instead). With the full
#   58-token intermediateTokens list this issues a LOT of eth_calls per
#   block - only use against an RPC that can handle the volume.
TRIGGER_MODE=poll

# How often to re-scan, in milliseconds. Only used when TRIGGER_MODE=poll.
# Dynamic mode issues a batch of eth_calls per scan (route generation +
# per-candidate quoting) - don't set this too low against a rate-limited
# public RPC.
POLL_INTERVAL_MS=6000

# If true, only logs what it WOULD execute - never sends a transaction.
# Always test with DRY_RUN=true first.
DRY_RUN=true

# Minimum acceptable net profit per trade, in the borrowed asset's smallest
# unit (wei-equivalent), as a decimal string. Passed straight into
# executeArbitrage's minProfit parameter. Static mode only - dynamic mode
# uses routes.config.json's per-asset minProfitByAssetAddress instead.
MIN_NET_PROFIT=0

# Slippage tolerance in basis points (0 = contract's on-chain default).
# Static mode only - dynamic mode uses routes.config.json's executionSlippageBps.
SLIPPAGE_BPS=0

# "true" (default): print a structured line for every REJECTED candidate too,
# not just accepted ones - this is what satisfies "detailed logs explaining
# why each opportunity is accepted or rejected". Set "false" once you've
# reviewed the reject reasons and just want to see real opportunities.
LOG_REJECTED=true

# "false" (default): one compact line per candidate. "true": pretty
# multi-line breakdown per candidate (gross/premium/gas/net/threshold each on
# their own line) - easier to read, much more verbose output.
VERBOSE_LOGS=false

# Optional. If set, starts a small read-only HTTP API (no auth, no writes,
# never touches PRIVATE_KEY) on this port serving /api/status,
# /api/opportunities, /api/metrics - this is what the frontend's "live
# opportunities" page polls. Leave unset to run with no HTTP surface at all.
# Only meaningful in SCAN_MODE=dynamic. If you expose this publicly, put it
# behind a reverse proxy (nginx/caddy) rather than binding it to 0.0.0.0
# directly on an internet-facing host.
API_PORT=4001
