# Root-level env file consumed by docker-compose.yml for the frontend's
# build-time NEXT_PUBLIC_* args. Copy to .env before running `docker compose
# up --build`. The keeper's own runtime secrets (PRIVATE_KEY, EXECUTOR_ADDRESS,
# RPC_URL, etc.) live in keeper/.env - see keeper/.env.example - and are
# never read by this file or baked into the frontend image.

NEXT_PUBLIC_CONTRACT_ADDRESS=0x145Fb0A33C157942a043D034b8D8b992d939F24f
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_KEEPER_API_URL=/keeper-api
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_EVENTS_LOOKBACK_BLOCKS=5000
