# Root-level env file consumed by docker-compose.yml: the frontend's
# build-time NEXT_PUBLIC_* args, plus RPC_URL passed as a runtime env var
# (read server-side by frontend/src/app/api/rpc/route.ts, never baked into
# the client bundle - see frontend/.env.example for the full explanation).
# Copy to .env before running `docker compose up --build`. The keeper's own
# runtime secrets (PRIVATE_KEY, EXECUTOR_ADDRESS, its own RPC_URL, etc.)
# live separately in keeper/.env - see keeper/.env.example.

NEXT_PUBLIC_CONTRACT_ADDRESS=0x145Fb0A33C157942a043D034b8D8b992d939F24f
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_KEEPER_API_URL=/keeper-api
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_EVENTS_LOOKBACK_BLOCKS=5000

# Server-only, put a paid/keyed BSC RPC endpoint here (e.g. a Tatum gateway
# URL with its xApiKey query param) - stays on the server, the browser only
# ever calls this app's own /api/rpc proxy.
RPC_URL=
