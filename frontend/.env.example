# Copy to .env.local for local dev, or pass as --build-arg values for the
# Docker build. All NEXT_PUBLIC_* vars are inlined into the client bundle at
# build time - never put a secret in one. This frontend never handles a
# private key; it only reads chain state and, when a wallet is connected,
# asks the user's own wallet extension to sign transactions.

# Deployed AaveArbitrageExecutorV3 address. Defaults to the live mainnet
# deployment (0x145Fb0A33C157942a043D034b8D8b992d939F24f) if unset.
NEXT_PUBLIC_CONTRACT_ADDRESS=

# BSC mainnet RPC endpoint used for reads and the connected wallet's chain
# config. Falls back to a public PublicNode endpoint if unset - fine for
# light/dev use, but set your own paid endpoint (Ankr/QuickNode/NodeReal) for
# real production traffic: free/public RPCs commonly rate-limit or reject
# direct browser requests (CORS), which is the single most common cause of
# "pages never finish loading" - the app now surfaces that as a visible red
# banner instead of silently hanging, but the fix is still a working RPC URL.
NEXT_PUBLIC_RPC_URL=

# Base URL of the keeper's read-only HTTP API (see ../keeper/.env.example's
# API_PORT). Leave unset to disable the "Live Opportunities" / keeper status
# widgets - the rest of the site works fine without it.
NEXT_PUBLIC_KEEPER_API_URL=

# WalletConnect/Reown project ID (free at https://cloud.reown.com). Without
# it, MetaMask/injected/Coinbase wallet connections still work; only the
# WalletConnect QR-code option is unavailable.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# How many recent blocks the Analytics/Transactions/Event Timeline pages
# scan for on-chain history. Larger = more history but more RPC calls on
# page load. Default 5000 (~4 hours of BSC blocks at ~3s/block).
NEXT_PUBLIC_EVENTS_LOOKBACK_BLOCKS=5000
